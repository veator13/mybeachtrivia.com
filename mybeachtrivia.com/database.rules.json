{
  "rules": {
    ".read": false,
    ".write": false,

    "games": {
      "$gameId": {
        "players": {
          ".read": "auth != null",

          "$uid": {
            ".write": "auth != null && auth.uid === $uid",

            "joinedAt": { ".validate": "newData.isNumber()" },
            "lastActive": { ".validate": "newData.isNumber()" }
          }
        },

        "joinLog": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "newData.hasChildren(['joinedAt']) && newData.child('joinedAt').isNumber()"
          }
        }
      }
    }
  }
}