{
  "rules": {
    ".read": false,
    ".write": false,

    "games": {
      "$gameId": {
        "players": {
          ".read": "auth != null",

          "$uid": {
            ".write": "auth != null && auth.uid === $uid",

            "joinedAt": { ".validate": "newData.isNumber() || newData.isObject()" },
            "lastActive": { ".validate": "newData.isNumber() || newData.isObject()" }
          }
        }
      }
    }
  }
}